{
  "name": "conot-discord-youtube-notifier",
  "version": "1.0.0",
  "description": "Discord bot notifikasi YouTube berbasis RSS tanpa YouTube Data API.",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "dev": "node --watch --env-file=.env src/index.js",
    "test": "node --test",
    "test:coverage": "c8 --check-coverage --lines 30 --functions 25 --branches 45 --statements 30 node --test",
    "lint": "eslint src test scripts --max-warnings=0",
    "lint:fix": "eslint src test scripts --fix",
    "lint:secrets": "node scripts/check-secrets.js",
    "backup:drill": "node scripts/backup-drill.js",
    "backup:restore:latest": "node scripts/restore-backup.js --latest",
    "backup:restore:dry-run": "node scripts/restore-backup.js --latest --dry-run",
    "start:pm2": "pm2 start ecosystem.config.cjs --only conot",
    "pm2:logs": "pm2 logs conot"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "axios": "^1",
    "discord.js": "^14",
    "rss-parser": "^3"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^8.57.1"
  },
  "c8": {
    "exclude": [
      "test/**",
      "scripts/**"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "reports-dir": "coverage"
  }
}
