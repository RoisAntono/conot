{
  "name": "@conot/dashboard-web",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.html",
  "scripts": {
    "start": "node --env-file=../../.env ../../node_modules/vite/bin/vite.js --host 0.0.0.0",
    "dev": "node --env-file=../../.env ../../node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node ../../node_modules/typescript/bin/tsc --noEmit && node ../../node_modules/vite/bin/vite.js build",
    "lint": "echo \"dashboard-web lint delegated to root\"",
    "test": "echo \"dashboard-web test delegated to root\"",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit",
    "test:e2e": "playwright test",
    "preview": "node --env-file=../../.env ../../node_modules/vite/bin/vite.js preview --host 0.0.0.0"
  },
  "dependencies": {
    "@conot/shared-types": "file:../../packages/shared-types",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
