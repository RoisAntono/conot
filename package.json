{
  "name": "conot-discord-youtube-notifier",
  "version": "1.0.0",
  "description": "Discord bot notifikasi YouTube berbasis RSS tanpa YouTube Data API.",
  "private": true,
  "main": "src/index.js",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/config/*"
  ],
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "dev": "node --watch --env-file=.env src/index.js",
    "dev:all": "turbo run dev --parallel",
    "dev:bot": "npm run dev --workspace @conot/bot",
    "dev:api": "npm run dev --workspace @conot/dashboard-api",
    "dev:web": "npm run dev --workspace @conot/dashboard-web",
    "build": "turbo run build",
    "lint:all": "turbo run lint",
    "test:all": "turbo run test",
    "typecheck": "turbo run typecheck",
    "build:workspaces": "npm run build --workspaces --if-present",
    "lint:workspaces": "npm run lint --workspaces --if-present",
    "test:workspaces": "npm run test --workspaces --if-present",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present",
    "test": "node --test",
    "test:coverage": "c8 --check-coverage --lines 30 --functions 25 --branches 45 --statements 30 node --test",
    "lint": "eslint src test scripts --max-warnings=0",
    "lint:fix": "eslint src test scripts --fix",
    "lint:secrets": "node scripts/check-secrets.js",
    "backup:drill": "node scripts/backup-drill.js",
    "backup:restore:latest": "node scripts/restore-backup.js --latest",
    "backup:restore:dry-run": "node scripts/restore-backup.js --latest --dry-run",
    "start:pm2": "pm2 start ecosystem.config.cjs --only conot",
    "pm2:logs": "pm2 logs conot"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "axios": "^1",
    "discord.js": "^14",
    "rss-parser": "^3"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^8.57.1",
    "turbo": "^2.9.12"
  },
  "c8": {
    "exclude": [
      "test/**",
      "scripts/**"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "reports-dir": "coverage"
  }
}
